/*PROBLEM STATEMENT :- Apply the concept of Dijkstra's Algorithm to find the Single Source Shortest Path of a Graph Data Structure */

#include <iostream>
using namespace std;

class Graph
{
    int n;
    int cost[10][10];

public:
    void input()
    {
        cout<<"Enter number of locations: ";
        cin>>n;

        cout<<"Enter distance matrix:\n";
        for(int i=0;i<n;i++)
        {
            for(int j=0;j<n;j++)
            {
                cin>>cost[i][j];
            }
        }
    }

    int minKey(int key[], bool visited[])
    {
        int min=9999, index;

        for(int i=0;i<n;i++)
        {
            if(!visited[i] && key[i]<min)
            {
                min=key[i];
                index=i;
            }
        }

        return index;
    }

    void dijkstra(int start)
    {
        int key[10], parent[10];
        bool visited[10];

        for(int i=0;i<n;i++)
        {
            key[i]=9999;
            visited[i]=false;
            parent[i]=-1;
        }

        key[start]=0;

        for(int count=0;count<n-1;count++)
        {
            int u=minKey(key,visited);
            visited[u]=true;

            for(int v=0;v<n;v++)
            {
                if(cost[u][v] && !visited[v] && key[u]+cost[u][v] < key[v])
                {
                    parent[v]=u;
                    key[v]=key[u]+cost[u][v];
                }
            }
        }

        cout<<"Location\tDistance\tParent\n";

        for(int i=0;i<n;i++)
        {
            cout<<i<<"\t\t"<<key[i]<<"\t\t"<<parent[i]<<endl;
        }
    }
};

int main()
{
    Graph obj;
    obj.input();
    obj.dijkstra(0);
}
